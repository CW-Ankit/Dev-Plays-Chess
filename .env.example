# =============================================================
# Root Environment Template (Monorepo)
# Copy values into package-specific env files where applicable.
# =============================================================

# ---------- Core URLs ----------
# Public Convex deployment URL used by web.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Public site URL used by auth integrations and callbacks.
NEXT_PUBLIC_CONVEX_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# ---------- Better Auth ----------
BETTER_AUTH_SECRET=replace_with_a_long_random_secret

# ---------- Dodo Payments (Optional unless payments are enabled) ----------
DODO_PAYMENTS_API_KEY=replace_with_dodo_api_key
DODO_ENVIRONMENT=test_mode
DODO_DEFAULT_PRODUCT_ID=pdt_placeholder_id
DODO_PAYMENTS_WEBHOOK_SECRET=replace_with_dodo_webhook_secret

# ---------- Mobile (Expo Public Variables) ----------
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=http://localhost:3000
