<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
</head>

<body>
    <main class="layout">
        <section class="board-column">
            <header class="game-header">
                <h1>Chess.com Style Arena</h1>
                <p data-status>Sign in and join queue.</p>
                <p data-role>You are waiting.</p>
                <p data-opponent>Opponent: -</p>
            </header>
            <div class="chessboard"></div>
            <footer class="game-actions hidden" data-game-actions>
                <button data-rematch>Rematch</button>
                <button data-new-opponent class="secondary">Play with someone else</button>
            </footer>
        </section>

        <aside class="sidebar">
            <section class="card" data-auth-card>
                <h2>Account</h2>
                <form data-register-form class="stack">
                    <h3>Register</h3>
                    <input name="name" type="text" placeholder="Display name" required />
                    <input name="email" type="email" placeholder="Email" required />
                    <input name="password" type="password" placeholder="Password" minlength="6" required />
                    <select name="preferredColor">
                        <option value="random">Random color</option>
                        <option value="white">White</option>
                        <option value="black">Black</option>
                    </select>
                    <button type="submit">Create account</button>
                </form>
                <form data-login-form class="stack">
                    <h3>Login</h3>
                    <input name="email" type="email" placeholder="Email" required />
                    <input name="password" type="password" placeholder="Password" minlength="6" required />
                    <select name="preferredColor">
                        <option value="random">Random color</option>
                        <option value="white">White</option>
                        <option value="black">Black</option>
                    </select>
                    <button type="submit">Login</button>
                </form>
            </section>

            <section class="card hidden" data-settings-card>
                <h2>Profile & Settings</h2>
                <p>Signed in as <strong data-user-name>-</strong></p>
                <form data-settings-form class="stack">
                    <input name="name" type="text" placeholder="Display name" required />
                    <select name="theme">
                        <option value="classic">Classic</option>
                        <option value="midnight">Midnight</option>
                    </select>
                    <select name="preferredColor">
                        <option value="random">Random color</option>
                        <option value="white">White</option>
                        <option value="black">Black</option>
                    </select>
                    <button type="submit">Save settings</button>
                </form>
                <button data-logout class="danger">Logout</button>
            </section>

            <section class="card hidden" data-history-card>
                <h2>Recent Games</h2>
                <ul data-history-list></ul>
            </section>
            <p class="notice" data-notice>Welcome! Authenticate to start.</p>
        </aside>
    </main>

    <div class="loading-overlay hidden" data-loading>
        <div class="loader-card">
            <h2>Finding opponent...</h2>
            <p data-loading-text>Please wait while we match you.</p>
        </div>
    </div>

    <script src="https://cdn.socket.io/4.8.3/socket.io.min.js"
        integrity="sha384-kzavj5fiMwLKzzD1f8S7TeoVIEi7uKHvbTA3ueZkrzYq75pNQUiUi6Dy98Q3fxb0"
        crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"
        integrity="sha512-xRllwz2gdZciIB+AkEbeq+gVhX8VB8XsfqeFbUh+SzHlN96dEduwtTuVuc2u9EROlmW9+yhRlxjif66ORpsgVA=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        window.__INITIAL_USER__ = <%- JSON.stringify(initialUser) %>
    </script>
    <script src="/javascripts/chessgame.js"></script>
</body>

</html>
