<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>
    <div class="app-shell <%= isAuthenticated ? '' : 'blurred' %>" data-app-shell>
        <section class="board-panel">
            <div class="panel-header">
                <h1>Chess Match</h1>
                <p data-game-status>White to move</p>
                <p data-player-role>You are Spectating</p>
            </div>
            <div class="chessboard"></div>
        </section>

        <aside class="auth-panel">
            <h2>Current Player</h2>
            <p>Name: <strong data-username><%= isAuthenticated ? username : 'Guest' %></strong></p>
            <p>Preferred side: <strong data-preferred-role><%= preferredRole %></strong></p>
            <p data-auth-message class="auth-message">Pick a name and side to start.</p>
            <button data-leave class="logout-btn <%= isAuthenticated ? '' : 'hidden' %>">Leave Game</button>
        </aside>
    </div>

    <div class="play-overlay <%= isAuthenticated ? 'hidden' : '' %>" data-play-overlay>
        <div class="play-card">
            <h2>Ready to Play?</h2>
            <p>Enter your name and choose how you want to join this match.</p>
            <form data-start-form class="auth-form">
                <label>
                    Your name
                    <input type="text" name="name" maxlength="24" placeholder="e.g. Magnus" required>
                </label>
                <label>
                    Play as
                    <select name="preferredRole">
                        <option value="any">Any available side</option>
                        <option value="w">White</option>
                        <option value="b">Black</option>
                        <option value="spectator">Spectator</option>
                    </select>
                </label>
                <button type="submit">Play</button>
            </form>
        </div>
    </div>

    <script src="https://cdn.socket.io/4.8.3/socket.io.min.js"
        integrity="sha384-kzavj5fiMwLKzzD1f8S7TeoVIEi7uKHvbTA3ueZkrzYq75pNQUiUi6Dy98Q3fxb0"
        crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"
        integrity="sha512-xRllwz2gdZciIB+AkEbeq+gVhX8VB8XsfqeFbUh+SzHlN96dEduwtTuVuc2u9EROlmW9+yhRlxjif66ORpsgVA=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        window.__INITIAL_AUTH__ = {
            isAuthenticated:  JSON.stringify(isAuthenticated) ,
            username:  JSON.stringify(username) ,
            preferredRole: JSON.stringify(preferredRole) 
        };
    </script>
    <script src="/javascripts/chessgame.js"></script>
</body>

</html>
